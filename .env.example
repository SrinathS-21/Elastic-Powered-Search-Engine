# API runtime settings.
# URL/port values are loaded from .env only.
APP_SCHEME=http
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional explicit public API URL for frontend runtime config.
# If omitted, frontend uses APP_SCHEME + APP_HOST + APP_PORT.
UI_API_BASE_URL=http://127.0.0.1:8000

# Optional logging controls.
# APP_LOG_LEVEL=INFO
# SEARCH_TRANSPORT_LOG_LEVEL=ERROR

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/admin

# Embedding API endpoint (external service only)
EMBEDDING_API_URL=http://127.0.0.1:8001
EMBED_REQUEST_TIMEOUT_SEC=20.0

# ============================================================================
# SEARCH BACKEND SELECTION
# ============================================================================
# Options: "elasticsearch" or "opensearch" (default: elasticsearch)
SEARCH_BACKEND=elasticsearch

# ============================================================================
# ELASTICSEARCH CONFIGURATION (Required)
# ============================================================================
# Main Elasticsearch endpoint (required)
ES_HOST=http://localhost:9200
# Optional connection timeout (seconds)
ES_REQUEST_TIMEOUT_SEC=20.0
# Optional: Elasticsearch index names
ES_INDEX=pepagora_products
ES_KEYWORD_INDEX=pepagora_keyword_cluster
# Optional: Elasticsearch authentication
# ES_USERNAME=
# ES_PASSWORD=

# ============================================================================
# OPENSEARCH CONFIGURATION (Required if SEARCH_BACKEND=opensearch)
# ============================================================================
# Main OpenSearch endpoint
# OPENSEARCH_HOST=http://localhost:9201
# Optional connection timeout (seconds)
# OPENSEARCH_REQUEST_TIMEOUT_SEC=20.0
# Optional: OpenSearch product aliases (recommended)
# OPENSEARCH_PRODUCT_READ_ALIAS=pepagora_products_read
# OPENSEARCH_PRODUCT_WRITE_ALIAS=pepagora_products_write
# Backward-compatible fallback key (read alias if present, otherwise this)
# OPENSEARCH_PRODUCT_INDEX=pepagora_products
# OPENSEARCH_KEYWORD_INDEX=pepagora_keyword_cluster
# Optional: OpenSearch authentication
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=password

